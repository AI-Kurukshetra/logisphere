# Supabase — get these from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy fallback if you still use the older key type:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: service role key for admin/server-only operations (never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email notifications — Resend
# Get your API key from https://resend.com
RESEND_API_KEY=
EMAIL_FROM=alerts@logisphere.io

# AI Forecasting (optional)
# Leave OPENAI_API_KEY blank to use internal linear regression fallback
# Spend analysis module will automatically use Codex API if key is present
# OPENAI_API_KEY is already used for intelligence recommendations
OPENAI_CODEX_MODEL=gpt-4-turbo

# Playwright Video Recording & Narration
# Get your API key from https://elevenlabs.io/
# Leave blank to use offline TTS (silent fallback for testing)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
